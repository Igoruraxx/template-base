# =============================================
# Environment Variables - Copy to .env
# =============================================

# Supabase (required for authentication and database)
# Find these in your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public site URL (used for auth redirects)
VITE_PUBLIC_SITE_URL=https://your-app.up.railway.app

# Optional: Stripe (for payment features)
# STRIPE_SECRET_KEY=sk_test_...

# Optional: Gemini AI (for OCR features)
# VITE_GEMINI_API_KEY=your-gemini-key-here
